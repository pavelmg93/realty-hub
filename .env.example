# RE Nha Trang - Environment Variables
# Copy this file to .env and fill in the values

# Application Database (pgvector)
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_NAME=re_nhatrang
APP_DB_USER=re_nhatrang
APP_DB_PASSWORD=change_me_in_production

# Kestra Database (internal metadata)
KESTRA_DB_HOST=localhost
KESTRA_DB_PORT=5433
KESTRA_DB_NAME=kestra
KESTRA_DB_USER=kestra
KESTRA_DB_PASSWORD=kestra_change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kestra
KESTRA_PORT=8080

# Kestra backup retention (days). Backups older than this are pruned.
KESTRA_BACKUP_DAYS=30

# Kestra API credentials (for flow sync script)
KESTRA_USER=user@email.com:password

# Google Gemini API (used by Kestra AI tasks)
ENV_GEMINI_API_KEY=your_gemini_api_key_here
